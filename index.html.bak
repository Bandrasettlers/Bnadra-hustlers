<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BANDRA HUSTLERS // AAA INTERACTIVE SYSTEM ARCHITECTURE</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;700;900&display=swap" rel="stylesheet" />
    
    <style>
        /* ============================================================
           CSS variables & Theme styling
           ============================================================ */
        :root {
            /* Intro Sunset Colors */
            --pink: #ff008c;
            --cyan: #00e5ff;
            --orange: #ff7a00;
            --yellow: #ffe600;
            --purple: #7f3dff;
            --red: #ff2f55;
            --white: #ffffff;
            --black: #050508;

            /* Homepage Theme Colors */
            --bg-current: #105B35;
            --ring-1: #00ff66;
            --ring-2: #ffaa00;
            --glass-bg: rgba(9, 7, 16, 0.9);
            --neon-glow: #00ff66;
        }

        * {
            margin: 0; padding: 0; box-sizing: border-box;
            font-family: 'Inter', sans-serif;
            user-select: none; -webkit-user-drag: none;
        }

        body, html { 
            width: 100%; height: 100vh; overflow: hidden; 
            background-color: var(--black); color: #fff;
        }

        /* ============================================================
           CINEMATIC INTRO EXPERIENCE
           ============================================================ */
        #intro {
            position: fixed;
            inset: 0;
            z-index: 99999;
            background-color: #000;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            pointer-events: auto;
            transition: transform 1.2s cubic-bezier(0.86, 0, 0.07, 1), 
                        filter 1.2s ease, 
                        opacity 1.2s ease;
            will-change: transform, opacity;
        }

        #camera {
            position: absolute;
            inset: -10%;
            display: flex;
            align-items: center;
            justify-content: center;
            transform-style: preserve-3d;
            will-change: transform;
            transition: transform 0.1s ease-out;
        }

        /* Camera shakes & zoom states */
        .camera-breath {
            animation: cameraBreathe 10s infinite ease-in-out alternate;
        }
        .camera-shake {
            animation: camShake 0.4s infinite;
        }
        .train-shake {
            animation: localTrainShake 0.5s infinite;
        }

        /* Sky: Sunset gradient */
        .sky-gradient {
            position: absolute;
            inset: 0;
            background: #000;
            transition: background 3.5s cubic-bezier(0.16, 1, 0.3, 1);
            z-index: 1;
        }
        .sky-sunset {
            background: radial-gradient(circle at bottom, rgba(255, 122, 0, 0.75) 0%, rgba(255, 0, 140, 0.45) 45%, rgba(127, 61, 255, 0.25) 75%, #05020c 100%),
                        linear-gradient(to top, #1c022e 0%, #080210 80%, #000 100%);
        }

        /* Floating Stars */
        .stars-overlay {
            position: absolute;
            inset: 0;
            background-image: radial-gradient(#fff 1px, transparent 1.2px);
            background-size: 50px 50px;
            opacity: 0.15;
            z-index: 2;
        }

        /* Sunset Sun Disc */
        .sun-disc {
            position: absolute;
            bottom: -320px;
            left: 50%;
            transform: translateX(-50%) scale(0.6);
            width: clamp(280px, 45vw, 420px);
            height: clamp(280px, 45vw, 420px);
            opacity: 0;
            z-index: 3;
            transition: transform 6s cubic-bezier(0.1, 0.8, 0.25, 1), opacity 4.5s ease;
        }
        .sun-up {
            transform: translate(-50%, -18vh) scale(1.3);
            opacity: 0.95;
        }

        /* Light Rays */
        .light-rays {
            position: absolute;
            inset: -40%;
            background: repeating-conic-gradient(from 0deg, rgba(255, 122, 0, 0.04) 0deg 15deg, transparent 15deg 30deg);
            opacity: 0;
            transform: rotate(0deg);
            animation: spinRays 90s linear infinite;
            z-index: 4;
            pointer-events: none;
            transition: opacity 3s ease;
        }

        /* Fluffy Silhouette Clouds */
        .cloud-layer {
            position: absolute;
            bottom: 24vh;
            width: 200%;
            height: 120px;
            background-repeat: repeat-x;
            opacity: 0;
            pointer-events: none;
            z-index: 5;
            transition: opacity 3s ease;
        }
        .cloud-back {
            left: -10%;
            background-image: radial-gradient(circle, rgba(127, 61, 255, 0.1) 25%, transparent 65%);
            background-size: 320px 100px;
            animation: driftLeft 40s linear infinite;
        }
        .cloud-front {
            left: 0;
            background-image: radial-gradient(circle, rgba(0, 229, 255, 0.06) 30%, transparent 70%);
            background-size: 400px 100px;
            animation: driftRight 28s linear infinite;
        }

        /* Post FX and Overlays */
        .film-grain {
            position: absolute;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.16'/%3E%3C/svg%3E");
            opacity: 0.14;
            mix-blend-mode: overlay;
            pointer-events: none;
            z-index: 200;
            animation: noiseShift 0.16s steps(2) infinite;
        }

        .scanlines {
            position: absolute;
            inset: 0;
            background: repeating-linear-gradient(0deg, rgba(255,255,255,0.02) 0px, rgba(255,255,255,0.02) 1px, transparent 2px, transparent 4px);
            pointer-events: none;
            z-index: 201;
        }

        .vignette {
            position: absolute;
            inset: 0;
            background: radial-gradient(circle, transparent 40%, rgba(0,0,0,0.85) 100%);
            pointer-events: none;
            z-index: 202;
        }

        /* Bandra Fort & Skyline Silhouette */
        .bandra-skyline {
            position: absolute;
            bottom: 20vh;
            left: 0;
            width: 100%;
            height: 28vh;
            fill: #05030a;
            opacity: 0;
            z-index: 6;
            transition: opacity 3s cubic-bezier(0.16, 1, 0.3, 1);
            filter: drop-shadow(0 -3px 12px rgba(127, 61, 255, 0.6)) drop-shadow(0 0 20px rgba(255, 0, 140, 0.4));
        }

        /* Blurry Silhouette of Bandra Fort Tower */
        .bandra-fort-silhouette {
            position: absolute;
            bottom: 20vh;
            left: 5%;
            width: 140px;
            height: 160px;
            fill: #030106;
            opacity: 0;
            z-index: 8;
            filter: blur(4px) drop-shadow(0 0 10px rgba(0,0,0,0.5));
            transition: opacity 3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .city-depth {
            position: absolute;
            bottom: 22vh;
            left: 0;
            width: 100%;
            height: 15vh;
            background-image: radial-gradient(#ffd166 1.2px, transparent 1.5px);
            background-size: 24px 18px;
            opacity: 0;
            z-index: 7;
            transition: opacity 2.2s cubic-bezier(0.16, 1, 0.3, 1);
            mask-image: linear-gradient(to top, white 20%, transparent 95%);
            -webkit-mask-image: linear-gradient(to top, white 20%, transparent 95%);
        }

        /* Dynamic Sea with Shimmer Reflections */
        .sea-layer {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 22vh;
            background: linear-gradient(180deg, #090412, #010004 80%);
            opacity: 0;
            z-index: 9;
            transition: opacity 3s ease;
        }

        .sea-reflection {
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at top, rgba(255, 0, 140, 0.22) 0%, rgba(0, 229, 255, 0.14) 35%, transparent 70%);
            mix-blend-mode: color-dodge;
            animation: seaGlow 5s infinite alternate ease-in-out;
        }

        .sea-wave {
            position: absolute;
            width: 200%;
            left: -50%;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--cyan), var(--pink), transparent);
            opacity: 0.12;
        }
        .wave1 { bottom: 80%; animation: waveFlow 8s infinite linear; }
        .wave2 { bottom: 50%; animation: waveFlowReverse 11s infinite linear; }
        .wave3 { bottom: 20%; animation: waveFlow 14s infinite linear; }

        /* Bandra Sea Link SVG Bridge */
        .sea-link {
            position: absolute;
            bottom: 20vh;
            left: 8%;
            width: 84%;
            height: 14vh;
            opacity: 0;
            z-index: 8;
            transition: opacity 3s ease;
            filter: drop-shadow(0 0 15px rgba(0, 229, 255, 0.95)) drop-shadow(0 0 30px rgba(0, 229, 255, 0.5));
        }

        /* Swaying Palms Silhouettes */
        .palms {
            position: absolute;
            bottom: 20vh;
            width: 100%;
            height: 13vh;
            pointer-events: none;
            z-index: 15;
        }

        .palm {
            position: absolute;
            bottom: 0;
            width: 3px;
            height: 95px;
            background: #030105;
            transform-origin: bottom center;
            animation: palmBreeze 4s infinite ease-in-out alternate;
        }

        .palm::after {
            content: "🌴";
            position: absolute;
            top: -20px;
            left: -22px;
            font-size: 32px;
            filter: brightness(0.06) drop-shadow(0 0 3px rgba(0, 229, 255, 0.22));
        }

        .palm-left { left: 12%; animation-delay: 0.2s; }
        .palm-right { right: 12%; animation-delay: 0.8s; height: 115px; }

        /* Glowing Streetlights */
        .street-lights {
            position: absolute;
            bottom: 20vh;
            left: 0;
            width: 100%;
            height: 4px;
            background-image: radial-gradient(circle, var(--yellow) 1.5px, transparent 2px);
            background-size: 60px 10px;
            opacity: 0;
            z-index: 10;
            transition: opacity 2s ease;
        }

        /* Bandra Local Train Container with Motion Blur */
        .train-wrapper {
            position: absolute;
            bottom: 14vh;
            left: -120%;
            width: 70%;
            height: 26px;
            z-index: 13;
            pointer-events: none;
            display: flex;
            align-items: center;
        }

        .train {
            width: 100%;
            height: 100%;
            background: linear-gradient(to right, #73121f, #e6005c 30%, #ffcc00 40%, #ffffff 48%, #666 100%);
            border-radius: 4px;
            box-shadow: 0 0 20px rgba(230, 0, 92, 0.4), inset -4px 0 #000;
            position: relative;
            filter: blur(0.5px);
        }

        .train-windows {
            width: 96%;
            height: 35%;
            position: absolute;
            top: 20%;
            left: 2%;
            background: repeating-linear-gradient(90deg, var(--yellow) 0px, var(--yellow) 10px, transparent 10px, transparent 22px);
            box-shadow: 0 0 6px var(--yellow);
        }

        /* Second local train in opposite direction (right-to-left) */
        .train-wrapper-2 {
            bottom: 11vh !important;
            left: auto !important;
            right: -120%;
        }

        .train-reverse {
            background: linear-gradient(to left, #73121f, #e6005c 30%, #ffcc00 40%, #ffffff 48%, #666 100%) !important;
            box-shadow: 0 0 20px rgba(0, 229, 255, 0.45), inset 4px 0 #000 !important;
        }

        /* Passing Cyber Traffic Vehicles */
        .traffic-lane {
            position: absolute;
            bottom: 9vh;
            width: 100%;
            height: 4px;
            z-index: 12;
        }

        .vehicle {
            position: absolute;
            bottom: 0;
            font-size: 15px;
            white-space: nowrap;
            opacity: 0.9;
            animation-timing-function: linear;
            animation-fill-mode: forwards;
        }

        /* Flying Seagulls */
        .birds span {
            position: absolute;
            width: 9px;
            height: 4px;
            border-top: 1.5px solid #000;
            border-left: 1.5px solid #000;
            border-radius: 2px 0 0 0;
            transform: rotate(45deg);
            opacity: 0;
            z-index: 4;
            animation: flockFly 9s infinite linear;
        }

        /* Comic Book Pop-up Stickers */
        .comic {
            position: absolute;
            font-family: 'Anton', sans-serif;
            font-size: clamp(2.2rem, 5.5vw, 4.8rem);
            font-weight: 900;
            color: var(--yellow);
            -webkit-text-stroke: 2.5px #000;
            text-shadow: 5px 5px 0px #000;
            transform: scale(0);
            z-index: 100;
            opacity: 0;
            pointer-events: none;
        }

        /* Bandra Station signboards & street plaques */
        .station-board {
            position: absolute;
            bottom: 21vh;
            left: 50%;
            transform: translate(-50%, 15px) scale(0.85);
            background: #ffd166;
            color: #000;
            font-family: 'Anton', sans-serif;
            font-size: clamp(12px, 2.8vw, 18px);
            padding: 5px 16px;
            border: 2.5px solid #000;
            box-shadow: 0 0 15px rgba(255, 209, 102, 0.5);
            opacity: 0;
            z-index: 50;
            transition: all 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .station-board.reveal {
            opacity: 1;
            transform: translate(-50%, 0) scale(1);
        }

        .location-sign {
            position: absolute;
            bottom: 22vh;
            background: #006400;
            border: 1.5px solid #fff;
            color: #fff;
            font-size: 10px;
            font-weight: 900;
            padding: 3px 8px;
            border-radius: 2px;
            box-shadow: 0 3px 8px rgba(0,0,0,0.5);
            opacity: 0;
            z-index: 49;
            transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.2);
            transform: translateY(15px);
        }

        /* Floating Street Stickers */
        .sticker-world {
            position: absolute;
            inset: 0;
            pointer-events: none;
            z-index: 45;
        }

        .sticker {
            position: absolute;
            font-size: clamp(18px, 3.5vw, 36px);
            opacity: 0;
            transition: opacity 0.8s ease, transform 0.8s ease;
            filter: drop-shadow(0 4px 6px rgba(0,0,0,0.5));
        }

        /* Massive Chrome Typography Logo */
        .hero {
            position: absolute;
            top: 36%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 90%;
            max-width: 800px;
            text-align: center;
            z-index: 110;
            display: flex;
            flex-direction: column;
            align-items: center;
            pointer-events: none;
        }

        .small-title {
            font-size: clamp(10px, 1.8vw, 14px);
            letter-spacing: 7px;
            color: var(--cyan);
            font-weight: 900;
            margin-bottom: 8px;
            opacity: 0;
            transform: translateY(-15px);
            transition: all 1s cubic-bezier(0.16, 1, 0.3, 1) 0.5s;
        }

        #logo {
            font-family: 'Anton', sans-serif;
            font-size: clamp(3rem, 11vw, 7.5rem);
            line-height: 0.95;
            letter-spacing: 1px;
            text-transform: uppercase;
            
            /* High-End Chrome/Liquid Metal texture using multi-stage metallic gradient */
            background: linear-gradient(to bottom, 
                #ffffff 0%, 
                #f1f1f1 28%, 
                #858585 45%, 
                #000000 48%, 
                #ff008c 50%, 
                #00e5ff 75%, 
                #ffffff 100%
            );
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            
            opacity: 0;
            transform: scale(0.9);
            transition: all 1s cubic-bezier(0.175, 0.885, 0.32, 1.15);
            filter: drop-shadow(0 0 15px rgba(255, 0, 140, 0.6)) drop-shadow(0 0 30px rgba(0, 229, 255, 0.4));
            position: relative;
        }

        #logo span {
            display: block;
            background: linear-gradient(to bottom, 
                #ffffff 0%, 
                #f1f1f1 28%, 
                #858585 45%, 
                #000000 48%, 
                #00e5ff 50%, 
                #ffe600 75%, 
                #ffffff 100%
            );
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 0 15px rgba(0, 229, 255, 0.6)) drop-shadow(0 0 30px rgba(255, 230, 0, 0.4));
        }

        .logo-glitch {
            animation: titleGlitchEffect 0.25s infinite alternate;
        }

        .hero-subtitle {
            font-size: clamp(9px, 1.5vw, 13px);
            letter-spacing: 4px;
            color: var(--yellow);
            margin-top: 12px;
            font-weight: 700;
            text-transform: uppercase;
            opacity: 0;
            transform: translateY(15px);
            transition: all 1s cubic-bezier(0.16, 1, 0.3, 1) 0.8s;
        }

        /* Elastic Action Words Pills */
        .action-sequence {
            position: absolute;
            bottom: 30%;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 12px;
            z-index: 100;
            pointer-events: none;
        }

        .action-sequence span {
            padding: 5px 12px;
            font-weight: 900;
            font-size: clamp(9px, 1.3vw, 11px);
            color: var(--yellow);
            border: 1.5px solid var(--yellow);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            transform: scale(0.2);
            opacity: 0;
            box-shadow: 0 0 10px rgba(255, 230, 0, 0.15);
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.25);
        }

        /* Rockstar Golden ID rotating badge card */
        .rockstar-card {
            position: absolute;
            bottom: 12%;
            left: 50%;
            transform: translateX(-50%) rotateX(75deg) rotateY(0deg) scale(0.8);
            background: linear-gradient(135deg, #d4af37 0%, #fff9e6 50%, #aa7c11 100%);
            border: 2px solid #fff;
            box-shadow: 0 15px 40px rgba(0,0,0,0.85), inset 0 0 10px rgba(255,255,255,0.5);
            width: clamp(210px, 40vw, 300px);
            height: clamp(110px, 22vw, 170px);
            border-radius: 10px;
            padding: 12px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: center;
            z-index: 120;
            opacity: 0;
            transform-origin: center center;
            transition: all 0.8s cubic-bezier(0.25, 1, 0.25, 1);
        }

        .rs-top {
            font-size: 10px;
            font-weight: 900;
            letter-spacing: 2px;
            color: #000;
            opacity: 0.8;
        }

        .rs-title {
            font-family: 'Anton', sans-serif;
            font-size: clamp(22px, 4.5vw, 30px);
            color: #000;
            letter-spacing: 1px;
            text-align: center;
            line-height: 1;
        }

        .rs-bottom {
            font-size: 9px;
            font-weight: 900;
            letter-spacing: 2.5px;
            color: #000;
            border-top: 1px solid rgba(0,0,0,0.2);
            padding-top: 4px;
            width: 100%;
            text-align: center;
        }

        /* Canvas Particle explosion layers */
        #particleCanvas {
            position: absolute;
            inset: 0;
            z-index: 95;
            pointer-events: none;
        }

        /* Lens flare & ambient sweeps */
        .lens-flare {
            position: absolute;
            left: 50%;
            top: 36%;
            transform: translate(-50%, -50%);
            width: 150vw;
            height: 30px;
            background: radial-gradient(ellipse at center, rgba(0, 229, 255, 0.7) 0%, rgba(255, 0, 140, 0.25) 30%, transparent 75%);
            mix-blend-mode: screen;
            z-index: 115;
            opacity: 0;
            transition: opacity 1s ease;
            pointer-events: none;
        }

        /* Screen Flash overlays - Disabled permanently */
        .white-flash {
            display: none !important;
        }

        /* Skip Button */
        .intro-skip {
            position: absolute;
            right: 24px;
            top: 24px;
            z-index: 100000;
            padding: 8px 18px;
            border-radius: 999px;
            border: 1.5px solid rgba(255,255,255,0.25);
            background: rgba(255, 255, 255, 0.05);
            color: #fff;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            cursor: pointer;
            font-weight: 700;
            font-size: 11px;
            letter-spacing: 2px;
            opacity: 0;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .intro-skip:hover {
            background: #fff;
            color: #000;
            transform: scale(1.05);
            border-color: #fff;
            box-shadow: 0 0 12px rgba(255,255,255,0.3);
        }

        /* Exit animation styles */
        #intro.exit-animate {
            transform: scale(2.2);
            filter: blur(35px);
            opacity: 0;
            pointer-events: none;
        }

        /* POP ART STYLE MULTI-STRIPE TRANSITION SWIPE OVERLAY */
        .pop-art-transition {
            position: fixed;
            inset: 0;
            z-index: 1000000;
            display: none;
            flex-direction: column;
            overflow: hidden;
            pointer-events: none;
        }
        .pop-art-transition .stripe {
            flex: 1;
            width: 100%;
            transform: translateX(-100%);
            transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .pop-art-transition .stripe-pink { background: var(--pink); z-index: 3; }
        .pop-art-transition .stripe-yellow { background: var(--yellow); z-index: 2; transition-delay: 0.04s; }
        .pop-art-transition .stripe-cyan { background: var(--cyan); z-index: 1; transition-delay: 0.08s; }

        .pop-art-text {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0) rotate(-10deg);
            font-family: 'Anton', sans-serif;
            font-size: clamp(3.5rem, 12vw, 8.5rem);
            color: #fff;
            -webkit-text-stroke: 3.5px #000;
            text-shadow: 10px 10px 0px #000, 0 0 40px rgba(255, 230, 0, 0.7);
            z-index: 10;
            transition: transform 0.45s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            white-space: nowrap;
        }

        /* Marathi Logo आमची वांद्रे Pop art Sticker (Moved down to avoid title overlap) */
        .marathi-logo {
            position: absolute;
            top: 55%;
            left: 12%;
            transform: translate(0, 0) scale(0) rotate(-8deg);
            font-family: 'Anton', 'Inter', sans-serif;
            font-weight: 900;
            font-size: clamp(1.2rem, 3.5vw, 1.8rem);
            color: #ffcc00;
            text-shadow: 4px 4px 0px #000, 0 0 15px rgba(255, 204, 0, 0.6);
            -webkit-text-stroke: 1.5px #fff;
            background: linear-gradient(135deg, rgba(230, 0, 92, 0.98), rgba(255, 0, 140, 0.98));
            padding: 6px 18px;
            border-radius: 12px;
            border: 3px solid #fff;
            z-index: 120;
            box-shadow: 8px 8px 0px #000, 0 10px 20px rgba(0,0,0,0.5);
            opacity: 0;
            transition: all 0.9s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            pointer-events: none;
        }

        /* Fisherman Boat floating gently */
        .fisherman-boat {
            position: absolute;
            bottom: 21vh;
            left: 20%;
            width: 75px;
            height: 48px;
            z-index: 10;
            opacity: 0;
            transition: opacity 3s ease;
            animation: boatFloat 7s infinite ease-in-out alternate;
            filter: drop-shadow(0 0 8px rgba(0, 229, 255, 0.3));
        }
        @keyframes boatFloat {
            0% { transform: translateY(0) rotate(-4deg); }
            100% { transform: translateY(-7px) rotate(5deg); }
        }

        /* Mount Mary Church Silhouette */
        .church-silhouette {
            position: absolute;
            bottom: 20vh;
            right: 18%;
            width: 110px;
            height: 140px;
            fill: #030106;
            opacity: 0;
            z-index: 7;
            filter: drop-shadow(0 0 12px rgba(0,0,0,0.75));
            transition: opacity 3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        /* Bollywood Star pop-art sticker (Moved down to avoid title overlap) */
        .bollywood-sticker {
            position: absolute;
            top: 58%;
            right: 10%;
            background: linear-gradient(135deg, #ff0055 0%, #ff5e00 100%);
            border: 3px solid #fff;
            border-radius: 14px;
            padding: 8px 14px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transform: scale(0) rotate(15deg);
            box-shadow: 8px 8px 0px #000;
            z-index: 100;
            opacity: 0;
            font-family: 'Anton', sans-serif;
            pointer-events: none;
            transition: all 0.75s cubic-bezier(0.175, 0.885, 0.32, 1.25);
        }
        .bollywood-sticker .shades-icon {
            font-size: 32px;
            animation: heartBeat 1.5s infinite;
        }
        .bollywood-sticker .star-label {
            font-size: 11px;
            color: #fff;
            font-weight: 900;
            letter-spacing: 1.5px;
            text-shadow: 1.5px 1.5px #000;
            margin-top: 6px;
            white-space: nowrap;
        }

        /* Audio dynamic helper prompter */
        .audio-prompt {
            position: absolute;
            bottom: 24px;
            left: 24px;
            background: rgba(0, 0, 0, 0.85);
            border: 1.5px solid var(--yellow);
            color: var(--yellow);
            border-radius: 999px;
            padding: 8px 18px;
            font-size: 10px;
            font-weight: 900;
            letter-spacing: 1.5px;
            z-index: 100000;
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 0 15px rgba(255, 230, 0, 0.35);
            pointer-events: none;
            opacity: 1;
            transition: opacity 0.5s ease;
            animation: promptPulse 1.5s infinite alternate ease-in-out;
        }
        @keyframes promptPulse {
            from { transform: scale(1); filter: brightness(0.9); }
            to { transform: scale(1.04); filter: brightness(1.2); }
        }


        /* ============================================================
           HOMEPAGE PORTED CUSTOM STYLES
           ============================================================ */
        .app-container {
            position: relative; 
            width: 100%; 
            height: 100vh; 
            overflow: hidden;
            background-color: var(--bg-current);
            transition: background-color 1000ms cubic-bezier(0.16, 1, 0.3, 1);
            z-index: 1;
            opacity: 0;
            transform: translateY(40px) scale(0.96);
            filter: blur(15px);
            transition: opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                        transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                        filter 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .app-container.reveal {
            opacity: 1;
            transform: translateY(0) scale(1);
            filter: blur(0px);
        }

        .ambient-shading {
            position: absolute; inset: 0; pointer-events: none; z-index: 50;
            background: radial-gradient(circle at 50% 35%, transparent 15%, rgba(1, 0, 4, 0.75) 85%);
            mix-blend-mode: multiply;
        }

        .grain-overlay {
            position: absolute; inset: 0; pointer-events: none; z-index: 51; opacity: 0.15;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='f'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23f)' opacity='0.12'/%3E%3C/svg%3E");
        }

        .audio-toggle {
            position: absolute; top: 24px; right: 32px; z-index: 60;
            background: rgba(255, 255, 255, 0.06); border: 2px solid rgba(255, 255, 255, 0.2);
            padding: 12px 26px; border-radius: 30px; color: white; font-size: 0.75rem;
            font-weight: 900; cursor: pointer; backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            box-shadow: 0 6px 24px rgba(0,0,0,0.4); transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            letter-spacing: 0.05em;
        }
        .audio-toggle:hover { background: #fff; color: #000; transform: scale(1.05); }

        .ring-system {
            position: absolute; top: 42%; left: 50%; transform: translate(-50%, -50%);
            width: 68vh; height: 68vh; pointer-events: none; z-index: 2;
        }
        .neon-ring-outer {
            position: absolute; inset: 0; border-radius: 50%;
            border: 6px solid var(--ring-1);
            box-shadow: 0 0 35px var(--ring-1), inset 0 0 20px var(--ring-1);
            animation: ringPulse 2.2s infinite alternate ease-in-out, ringFlicker 0.18s infinite;
        }
        .neon-ring-inner {
            position: absolute; inset: 24px; border-radius: 50%;
            border: 4px solid var(--ring-2);
            box-shadow: 0 0 45px var(--ring-2), inset 0 0 22px var(--ring-2);
            animation: ringPulse 1.6s infinite alternate-reverse ease-in-out;
        }

        .ring-nav-btn {
            position: absolute; top: 42%; transform: translateY(-50%);
            width: 76px; height: 76px; border-radius: 50%;
            background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); cursor: pointer; z-index: 45;
            display: flex; align-items: center; justify-content: center; color: rgba(255, 255, 255, 0.4);
            box-shadow: 0 8px 32px rgba(0,0,0,0.2);
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .ring-nav-btn:hover { 
            background: rgba(255, 255, 255, 0.12); border-color: rgba(255, 255, 255, 0.4); 
            transform: translateY(-50%) scale(1.08); color: rgba(255, 255, 255, 0.9);
            box-shadow: 0 0 20px rgba(255,255,255,0.15);
        }
        .ring-nav-left { left: calc(50% - 47vh); }
        .ring-nav-right { right: calc(50% - 47vh); }
        .ring-nav-btn svg { width: 28px; height: 28px; fill: none; stroke: currentColor; stroke-width: 2.5; }

        .ghost-text {
            position: absolute; top: 5%; left: 50%; transform: translateX(-50%);
            pointer-events: none; font-family: 'Anton', sans-serif; font-size: clamp(90px, 24vw, 340px);
            font-weight: 900; color: rgba(255, 255, 255, 0.15); text-transform: uppercase; 
            white-space: nowrap; z-index: 1; letter-spacing: -0.01em;
        }

        .stage-container { position: absolute; inset: 0; z-index: 3; perspective: 1800px; }
        .character-wrapper {
            position: absolute; aspect-ratio: 0.58 / 1; will-change: transform, filter, opacity;
            transition: all 900ms cubic-bezier(0.16, 1, 0.3, 1);
        }
        .character-wrapper img { 
            width: 100%; height: 100%; object-fit: contain; object-position: bottom center; 
            animation: heroBreathing 5s infinite alternate ease-in-out;
        }

        .props-container { position: absolute; inset: 0; z-index: 4; pointer-events: none; }
        
        .aaa-diorama-card {
            position: absolute; width: 260px; height: 260px;
            will-change: transform, opacity;
            transition: all 1200ms cubic-bezier(0.16, 1, 0.3, 1);
        }

        .role-center { left: 50%; bottom: 15%; height: 85%; transform: translateX(-50%) translateZ(150px); opacity: 1; z-index: 20; filter: blur(0); }
        .role-left { left: 16%; bottom: 20%; height: 32%; transform: translateX(-50%) translateZ(-350px) rotateY(45deg); filter: blur(5px) grayscale(40%); opacity: 0.45; z-index: 10; }
        .role-right { left: 84%; bottom: 20%; height: 32%; transform: translateX(-50%) translateZ(-350px) rotateY(-45deg); filter: blur(5px) grayscale(40%); opacity: 0.45; z-index: 10; }
        .role-back { left: 50%; bottom: 24%; height: 18%; transform: translateX(-50%) translateZ(-800px); filter: blur(15px); opacity: 0.04; z-index: 5; }

        .bottom-console {
            position: absolute; bottom: 24px; left: 24px; right: 24px; z-index: 60;
            background: var(--glass-bg); backdrop-filter: blur(45px) saturate(210%);
            -webkit-backdrop-filter: blur(45px) saturate(210%);
            border: 1px solid rgba(255, 255, 255, 0.14); border-radius: 24px;
            padding: 26px 40px; display: grid; grid-template-columns: 360px 1fr 400px;
            gap: 40px; align-items: center;
            box-shadow: 0 45px 90px rgba(0,0,0,0.9), inset 0 1px 2px rgba(255,255,255,0.2);
        }

        .ui-title { font-family: 'Anton', sans-serif; font-size: 2.8rem; color: #fff; line-height: 0.95; text-transform: uppercase; letter-spacing: 0.01em; }
        .brand-meta { font-size: 0.72rem; font-weight: 900; color: var(--ring-2); letter-spacing: 0.25em; text-transform: uppercase; margin-bottom: 8px; }
        .ui-desc { font-size: 0.88rem; color: rgba(255, 255, 255, 0.75); line-height: 1.55; font-weight: 500; }

        .console-right-panel { display: flex; flex-direction: column; gap: 14px; }
        
        .compact-deal-box {
            background: linear-gradient(135deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.01) 100%);
            border: 1px dashed rgba(255, 255, 255, 0.22); border-radius: 12px; padding: 12px 18px;
            display: flex; justify-content: space-between; align-items: center;
            position: relative; overflow: hidden;
        }

        .deal-vendor { font-size: 0.72rem; color: var(--ring-2); font-weight: 900; text-transform: uppercase; letter-spacing: 0.06em; }
        .deal-text { font-size: 0.82rem; color: #fff; font-weight: 700; }

        .launcher-btn {
            width: 100%; background: #fff; color: #000; border: none; border-radius: 30px;
            padding: 16px; font-family: 'Anton', sans-serif; font-size: 1.35rem;
            letter-spacing: 0.05em; text-transform: uppercase; cursor: pointer; text-align: center; text-decoration: none;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); display: flex; align-items: center; justify-content: center;
        }
        .launcher-btn:hover { 
            background: var(--neon-glow); transform: translateY(-3px); 
            box-shadow: 0 12px 30px rgba(0,255,102,0.45);
        }

        /* Replay-Intro on the footer console */
        .system-footer {
            position: absolute;
            top: 24px;
            left: 32px;
            z-index: 60;
            display: flex;
            gap: 12px;
        }

        .replay-btn {
            background: rgba(255, 255, 255, 0.06); 
            border: 2px solid rgba(255, 255, 255, 0.20);
            padding: 12px 22px; 
            border-radius: 30px; 
            color: #ccc; 
            font-size: 0.7rem;
            font-weight: 900; 
            cursor: pointer; 
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            box-shadow: 0 6px 24px rgba(0,0,0,0.4); 
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            letter-spacing: 0.05em;
        }
        .replay-btn:hover {
            background: var(--pink);
            border-color: var(--pink);
            color: #fff;
            transform: scale(1.05);
            box-shadow: 0 0 15px rgba(255, 0, 140, 0.4);
        }

        /* Interactive Spraypaint Wall & Chai Clicker modal triggers inside Homepage */
        .interactive-sidebar {
            position: absolute;
            top: 100px;
            right: 32px;
            width: 320px;
            z-index: 55;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .side-card {
            background: var(--glass-bg);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 16px;
            padding: 18px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.6);
        }

        .side-title {
            font-family: 'Anton', sans-serif;
            font-size: 1.15rem;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            margin-bottom: 10px;
            color: var(--ring-1);
        }

        #graffitiCanvas {
            background: #050508;
            border: 1px dashed rgba(255,255,255,0.2);
            border-radius: 8px;
            cursor: crosshair;
            width: 100%;
            height: 120px;
        }

        .color-palette {
            display: flex;
            gap: 8px;
            margin-top: 10px;
            align-items: center;
        }

        .color-dot {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            cursor: pointer;
            border: 1.5px solid transparent;
            transition: transform 0.2s;
        }

        .color-dot.active {
            border-color: #fff;
            transform: scale(1.2);
        }

        .side-btn {
            background: rgba(255,0,50,0.1);
            color: var(--red);
            border: 1px solid rgba(255,0,50,0.3);
            font-size: 0.65rem;
            font-weight: 900;
            padding: 4px 8px;
            border-radius: 4px;
            cursor: pointer;
            text-transform: uppercase;
            margin-left: auto;
        }

        .chai-container {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .chai-cup {
            font-size: 42px;
            cursor: pointer;
            transition: transform 0.1s;
        }

        .chai-cup:active {
            transform: scale(0.8) rotate(-10deg);
        }

        .chai-badge {
            background: rgba(255, 122, 0, 0.2);
            border: 1px solid var(--orange);
            color: var(--orange);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.72rem;
            font-weight: 900;
        }

        .toast-popup {
            position: absolute;
            color: var(--yellow);
            font-family: 'Anton', sans-serif;
            font-size: 18px;
            pointer-events: none;
            animation: stickerSwayUp 0.8s ease-out forwards;
        }


        /* ============================================================
           HOMEPAGE KEYFRAMES
           ============================================================ */
        @keyframes ringPulse {
            0% { transform: scale(0.98); filter: brightness(0.9); }
            100% { transform: scale(1.03); filter: brightness(1.3); }
        }
        @keyframes ringFlicker {
            0%, 100% { opacity: 1; }
            33% { opacity: 0.95; }
            64% { opacity: 0.98; }
        }

        @keyframes heroBreathing {
            0% { transform: translateY(0) scale(1); filter: drop-shadow(0 20px 30px rgba(0,0,0,0.45)); }
            100% { transform: translateY(-12px) scale(1.02); filter: drop-shadow(0 35px 60px rgba(0,0,0,0.65)) brightness(1.12); }
        }

        @keyframes d-orbit-left {
            0% { transform: translateY(0px) rotate(-2deg) scale(1); }
            50% { transform: translateY(-15px) rotate(2deg) scale(1.03); }
            100% { transform: translateY(0px) rotate(-2deg) scale(1); }
        }
        @keyframes d-orbit-topright {
            0% { transform: translateY(0px) rotate(4deg) scale(1); }
            50% { transform: translateY(-22px) rotate(-1deg) scale(1.04); }
            100% { transform: translateY(0px) rotate(4deg) scale(1); }
        }
        @keyframes d-orbit-bottomright {
            0% { transform: translateY(0px) rotate(-3deg) scale(1); }
            50% { transform: translateY(12px) rotate(3deg) scale(0.97); }
            100% { transform: translateY(0px) rotate(-3deg) scale(1); }
        }


        /* ============================================================
           INTRO TIMELINE KEYFRAMES
           ============================================================ */
        @keyframes cameraBreathe {
            0% { transform: scale(1) rotate(0deg); }
            100% { transform: scale(1.03) rotate(0.5deg); }
        }

        @keyframes camShake {
            0%, 100% { transform: translate(0, 0) rotate(0); }
            20% { transform: translate(-1.5px, 1.5px) rotate(-0.5deg); }
            40% { transform: translate(1.5px, -1.5px) rotate(0.5deg); }
            60% { transform: translate(-1.5px, -1.5px) rotate(0.2deg); }
            80% { transform: translate(1.5px, 1.5px) rotate(-0.2deg); }
        }

        @keyframes localTrainShake {
            0%, 100% { transform: translate(0, 0) rotate(0); }
            10% { transform: translate(-3px, 3px) rotate(-1.2deg); }
            20% { transform: translate(4px, -2px) rotate(1deg); }
            30% { transform: translate(-4px, -3px) rotate(-1.5deg); }
            40% { transform: translate(3px, 4px) rotate(1.2deg); }
            50% { transform: translate(-2px, -3px) rotate(-0.8deg); }
            60% { transform: translate(3px, 2px) rotate(1.1deg); }
            70% { transform: translate(-4px, 1px) rotate(-1deg); }
            80% { transform: translate(2px, -3px) rotate(0.8deg); }
            90% { transform: translate(-2px, 2px) rotate(-0.5deg); }
        }

        @keyframes driftLeft {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        @keyframes driftRight {
            0% { transform: translateX(0); }
            100% { transform: translateX(50%); }
        }

        @keyframes noiseShift {
            0%, 100% { transform: translate(0, 0); }
            20% { transform: translate(-2px, 3px); }
            40% { transform: translate(3px, -1px); }
            60% { transform: translate(-3px, -3px); }
            80% { transform: translate(2px, 2px); }
        }

        @keyframes seaGlow {
            from { opacity: 0.55; filter: hue-rotate(0deg); }
            to { opacity: 0.9; filter: hue-rotate(35deg); }
        }

        @keyframes waveFlow {
            0% { transform: translateX(0); }
            100% { transform: translateX(50%); }
        }

        @keyframes waveFlowReverse {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        @keyframes palmBreeze {
            from { transform: rotate(-3deg); }
            to { transform: rotate(4deg); }
        }

        @keyframes flockFly {
            0% { transform: translate(-25vw, 12vh) rotate(5deg) scale(0.5); opacity: 0; }
            10% { opacity: 0.75; }
            90% { opacity: 0.75; }
            100% { transform: translate(125vw, -12vh) rotate(-3deg) scale(0.5); opacity: 0; }
        }

        @keyframes bounceInSticker {
            0% { transform: scale(0.12) rotate(-25deg); opacity: 0; }
            50% { transform: scale(1.22) rotate(10deg); opacity: 1; }
            75% { transform: scale(0.9) rotate(-5deg); }
            100% { transform: scale(1) rotate(0deg); opacity: 1; }
        }

        @keyframes titleGlitchEffect {
            0% { transform: scale(1) translate(0, 0); filter: hue-rotate(0deg); }
            5% { transform: translate(-2px, 2px) skewX(-2deg); filter: saturate(1.5); }
            10% { transform: translate(3px, -1px); }
            15% { transform: translate(0, 0); }
            85% { transform: translate(0, 0); }
            90% { transform: translate(-4px, 3px) skewX(4deg); filter: contrast(1.3); }
            95% { transform: translate(4px, -2px); filter: hue-rotate(45deg); }
            100% { transform: scale(1.02); }
        }

        @keyframes stickerSwayUp {
            0% { transform: translateY(0) scale(1); opacity: 1; }
            100% { transform: translateY(-70px) scale(0.85); opacity: 0; }
        }

        /* ============================================================
           AAA IMMERSIVE CONSOLE MODALS STYLING
           ============================================================ */
        .system-modal {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background-color: rgba(5, 3, 10, 0.96);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            animation: modalFadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 2px solid rgba(255, 255, 255, 0.05);
        }

        @keyframes modalFadeIn {
            from { opacity: 0; transform: scale(1.05); }
            to { opacity: 1; transform: scale(1); }
        }

        .modal-glow-bg {
            position: absolute;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 50% 50%, rgba(255, 0, 140, 0.15) 0%, rgba(0, 229, 255, 0.1) 50%, transparent 100%);
            pointer-events: none;
            z-index: 1;
        }

        .modal-container {
            position: relative;
            z-index: 2;
            width: 92%;
            max-width: 1200px;
            height: 85vh;
            background: rgba(10, 8, 18, 0.88);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 24px;
            box-shadow: 0 50px 100px rgba(0,0,0,0.95), 0 0 40px rgba(0, 229, 255, 0.15);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .modal-header {
            padding: 20px 32px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(0, 0, 0, 0.4);
        }

        .modal-header-meta {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        #modalMetaCategory {
            font-size: 0.75rem;
            font-weight: 900;
            letter-spacing: 3px;
            color: var(--cyan);
            text-transform: uppercase;
        }

        .modal-live-indicator {
            font-size: 0.65rem;
            font-weight: 900;
            color: var(--ring-1);
            letter-spacing: 1px;
            animation: pulseOpacity 1.5s infinite alternate ease-in-out;
        }

        @keyframes pulseOpacity {
            0% { opacity: 0.4; }
            100% { opacity: 1; }
        }

        .modal-close-btn {
            background: transparent;
            border: 1.5px solid var(--red);
            border-radius: 999px;
            padding: 6px 16px;
            color: var(--red);
            font-weight: 900;
            font-size: 0.7rem;
            letter-spacing: 2px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .modal-close-btn:hover {
            background: var(--red);
            color: #fff;
            box-shadow: 0 0 15px var(--red);
            transform: scale(1.05);
        }

        .close-icon {
            font-size: 1.1rem;
            line-height: 1;
        }

        .modal-body {
            flex: 1;
            overflow-y: auto;
            position: relative;
        }

        .modal-panel {
            width: 100%;
            height: 100%;
            padding: 32px;
        }

        /* ============================================================
           A. WEBTOONS INTERACTIVE PANEL
           ============================================================ */
        .webtoons-layout {
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 32px;
            height: 100%;
        }

        .webtoons-sidebar {
            border-right: 1px solid rgba(255, 255, 255, 0.08);
            padding-right: 24px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .panel-subtitle {
            font-size: 0.75rem;
            letter-spacing: 2px;
            color: rgba(255, 255, 255, 0.4);
            font-weight: 900;
            text-transform: uppercase;
        }

        .comic-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .comic-card {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.06);
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .comic-card:hover, .comic-card.active {
            background: rgba(255, 255, 255, 0.08);
            border-color: var(--cyan);
            box-shadow: 0 0 15px rgba(0, 229, 255, 0.15);
        }

        .comic-thumb {
            width: 44px;
            height: 44px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .comic-emoji {
            font-size: 1.4rem;
        }

        .comic-details h4 {
            font-size: 0.85rem;
            font-weight: 900;
            color: #fff;
            margin-bottom: 2px;
            letter-spacing: 0.5px;
        }

        .comic-details p {
            font-size: 0.72rem;
            color: rgba(255, 255, 255, 0.5);
            font-weight: 500;
        }

        .webtoons-reader {
            height: 100%;
            overflow-y: auto;
            background: #000;
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 32px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 16px;
            scroll-behavior: smooth;
        }

        /* Comic panel graphics styling */
        .comic-frame {
            width: 100%;
            max-width: 460px;
            background: #0d0a15;
            border: 4px solid #fff;
            box-shadow: 10px 10px 0px #000, 0 10px 25px rgba(0,0,0,0.8);
            padding: 16px;
            position: relative;
            transform: rotate(var(--rot, 0.5deg));
            transition: transform 0.3s ease;
        }

        .comic-frame:hover {
            transform: rotate(0deg) scale(1.02);
        }

        .comic-frame-img-box {
            width: 100%;
            aspect-ratio: 1.3 / 1;
            background-color: #120f21;
            border: 2px solid #000;
            overflow: hidden;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .comic-grid-bg {
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(255, 0, 140, 0.2) 1.5px, transparent 1.5px);
            background-size: 12px 12px;
        }

        .comic-frame-content {
            font-size: 3.5rem;
            z-index: 2;
            position: relative;
            filter: drop-shadow(0 4px 8px rgba(0,0,0,0.5));
        }

        .comic-bubble {
            position: absolute;
            background: #fff;
            border: 2px solid #000;
            border-radius: 16px;
            padding: 8px 12px;
            color: #000;
            font-size: 0.72rem;
            font-weight: 800;
            line-height: 1.3;
            max-width: 160px;
            z-index: 10;
            box-shadow: 3px 3px 0 rgba(0,0,0,0.25);
        }

        .bubble-left {
            top: 10px;
            left: 10px;
        }

        .bubble-right {
            bottom: 12px;
            right: 10px;
        }

        .comic-narrator {
            background: var(--yellow);
            border: 2px solid #000;
            color: #000;
            padding: 4px 10px;
            font-size: 0.65rem;
            font-weight: 900;
            letter-spacing: 1px;
            position: absolute;
            top: -10px;
            left: 15px;
            z-index: 11;
            text-transform: uppercase;
        }

        /* ============================================================
           B. RETRO ARCADE GAME PANEL (RICKSHAW DRIFT)
           ============================================================ */
        /* Netflix Style Game Selection UI */
        .arcade-netflix-container {
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            padding: 24px;
            color: #fff;
            box-sizing: border-box;
        }

        .netflix-arcade-header {
            margin-bottom: 24px;
            border-left: 4px solid var(--pink);
            padding-left: 14px;
        }

        .netflix-arcade-header h2 {
            font-family: 'Anton', 'Impact', sans-serif;
            font-size: 2rem;
            letter-spacing: 2px;
            color: #fff;
            text-shadow: 0 0 10px rgba(255, 0, 140, 0.4);
            margin: 0 0 4px 0;
        }

        .netflix-arcade-header p {
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.6);
            margin: 0;
        }

        .netflix-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
            padding-bottom: 40px;
        }

        .netflix-card {
            background: linear-gradient(135deg, rgba(20, 15, 35, 0.95) 0%, rgba(10, 8, 18, 0.95) 100%);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 24px;
            position: relative;
            cursor: pointer;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 220px;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .netflix-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at top right, rgba(0, 229, 255, 0.15), transparent 60%);
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .netflix-card:hover::before {
            opacity: 1;
        }

        .netflix-card:hover {
            transform: translateY(-8px) scale(1.02);
            border-color: var(--pink);
            box-shadow: 0 20px 40px rgba(255, 0, 140, 0.25), 0 0 20px rgba(0, 229, 255, 0.1);
        }

        .card-tag {
            position: absolute;
            top: 14px;
            right: 14px;
            background: var(--pink);
            color: #fff;
            font-size: 10px;
            font-weight: 900;
            padding: 4px 8px;
            border-radius: 4px;
            letter-spacing: 1px;
            text-transform: uppercase;
            box-shadow: 0 0 10px rgba(255, 0, 140, 0.5);
        }

        .card-icon {
            font-size: 38px;
            margin-bottom: 12px;
            transition: transform 0.3s ease;
        }

        .netflix-card:hover .card-icon {
            transform: scale(1.15) rotate(-5deg);
        }

        .card-title {
            font-family: 'Anton', sans-serif;
            font-size: 1.35rem;
            color: #ffcc00;
            letter-spacing: 1px;
            margin-bottom: 8px;
            text-shadow: 2px 2px 0px #000;
        }

        .card-desc {
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.7);
            line-height: 1.4;
            margin-bottom: 16px;
            flex-grow: 1;
        }

        .card-play-btn {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 8px;
            color: #fff;
            font-family: 'Anton', sans-serif;
            font-size: 0.9rem;
            letter-spacing: 1px;
            padding: 10px;
            width: 100%;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .netflix-card:hover .card-play-btn {
            background: var(--pink);
            border-color: var(--pink);
            box-shadow: 0 0 15px rgba(255, 0, 140, 0.5);
        }

        /* Active game stage styling */
        #active-game-stage {
            display: flex;
            flex-direction: column;
            width: 100%;
            height: 100%;
        }

        .stage-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding-bottom: 12px;
        }

        .back-to-selector-btn {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: #fff;
            font-size: 0.75rem;
            font-weight: bold;
            padding: 8px 16px;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .back-to-selector-btn:hover {
            background: #fff;
            color: #000;
            transform: translateX(-4px);
        }

        .active-game-title {
            font-family: 'Anton', sans-serif;
            font-size: 1.5rem;
            letter-spacing: 1.5px;
            color: var(--cyan);
            text-shadow: 0 0 8px rgba(0, 229, 255, 0.4);
        }

        .active-game-body {
            flex-grow: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #020105;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 20px;
            position: relative;
            overflow: auto;
            min-height: 480px;
        }

        /* Standard Split Game layout */
        .arcade-classic-layout {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 24px;
            width: 100%;
            height: 100%;
            align-items: center;
        }

        .game-info-sidebar {
            display: flex;
            flex-direction: column;
            gap: 16px;
            background: rgba(0,0,0,0.4);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 16px;
            padding: 20px;
            height: 100%;
            justify-content: space-between;
        }

        .game-info-sidebar h3 {
            font-family: 'Anton', sans-serif;
            font-size: 1.4rem;
            color: var(--yellow);
            letter-spacing: 1px;
            margin: 0;
        }

        .game-instructions-text {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.65);
            line-height: 1.5;
            margin: 0;
        }

        .arcade-score-panel {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .arcade-score-item {
            display: flex;
            justify-content: space-between;
            background: rgba(255, 255, 255, 0.04);
            padding: 8px 12px;
            border-radius: 8px;
            font-size: 0.8rem;
            border: 1px solid rgba(255,255,255,0.04);
        }

        .arcade-score-item span {
            color: rgba(255,255,255,0.4);
            font-weight: 700;
        }

        .arcade-score-item strong {
            color: #fff;
            font-family: 'Anton', sans-serif;
            font-size: 1.1rem;
        }

        .canvas-wrapper-cinematic {
            display: flex;
            align-items: center;
            justify-content: center;
            background: #04020a;
            border: 4px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            box-shadow: inset 0 0 30px rgba(0, 229, 255, 0.2), 0 20px 50px rgba(0,0,0,0.8);
            overflow: hidden;
            padding: 10px;
        }

        .canvas-wrapper-cinematic canvas {
            display: block;
            border-radius: 8px;
        }

        /* WASD Keys visual pad */
        .retro-wasd-keys {
            display: grid;
            grid-template-columns: 1fr;
            gap: 6px;
            justify-items: center;
            margin-top: 10px;
        }

        .retro-wasd-keys button {
            background: rgba(255,255,255,0.06);
            border: 1.5px solid rgba(255,255,255,0.15);
            color: #fff;
            width: 38px;
            height: 38px;
            font-size: 1rem;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.15s;
        }

        .retro-wasd-keys button:active {
            background: var(--pink);
            color: #fff;
            border-color: var(--pink);
            transform: scale(0.9);
        }

        .retro-wasd-keys div {
            display: flex;
            gap: 6px;
        }

        /* 2. SUDOKU LAYOUT STYLING */
        .sudoku-layout {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 24px;
            width: 100%;
            height: 100%;
            align-items: center;
        }

        .sudoku-panel {
            display: flex;
            flex-direction: column;
            gap: 16px;
            background: rgba(0,0,0,0.4);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 16px;
            padding: 20px;
            height: 100%;
            justify-content: space-between;
        }

        .sudoku-panel h3 {
            font-family: 'Anton', sans-serif;
            font-size: 1.4rem;
            color: var(--yellow);
            letter-spacing: 1px;
            margin: 0;
        }

        .sudoku-controls {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .arcade-btn-action {
            background: var(--pink);
            border: none;
            color: #fff;
            font-family: 'Anton', sans-serif;
            font-size: 0.9rem;
            letter-spacing: 1px;
            padding: 12px;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s;
            text-shadow: 1px 1px 2px #000;
        }

        .arcade-btn-action:hover {
            transform: translateY(-2px);
            filter: brightness(1.1);
            box-shadow: 0 5px 15px rgba(255, 0, 140, 0.4);
        }

        .sudoku-msg {
            font-size: 0.8rem;
            color: var(--cyan);
            font-weight: bold;
            min-height: 20px;
            text-align: center;
        }

        .sudoku-grid-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .sudoku-grid {
            display: grid;
            grid-template-columns: repeat(9, 42px);
            grid-template-rows: repeat(9, 42px);
            gap: 1px;
            background: rgba(255,255,255,0.08);
            border: 4px solid var(--cyan);
            border-radius: 12px;
            padding: 6px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.8);
        }

        .sudoku-cell {
            width: 42px;
            height: 42px;
            background: #090615;
            border: 1px solid rgba(255,255,255,0.04);
            color: #fff;
            font-family: 'Inter', sans-serif;
            font-size: 16px;
            font-weight: bold;
            text-align: center;
            line-height: 42px;
            cursor: pointer;
            user-select: none;
            transition: all 0.2s;
        }

        .sudoku-cell:hover {
            background: rgba(255, 255, 255, 0.08);
        }

        /* Bold borders to delineate 3x3 blocks */
        .sudoku-cell:nth-child(3n) {
            border-right: 2px solid var(--cyan);
        }
        .sudoku-cell:nth-child(9n) {
            border-right: none;
        }
        .sudoku-grid > div:nth-child(n+19):nth-child(-n+27),
        .sudoku-grid > div:nth-child(n+46):nth-child(-n+54) {
            border-bottom: 2px solid var(--cyan);
        }

        .sudoku-cell-pre {
            color: var(--yellow);
            background: rgba(255, 209, 102, 0.06);
            cursor: not-allowed;
        }

        .sudoku-cell-err {
            background: rgba(255, 0, 85, 0.15) !important;
            color: var(--red) !important;
            animation: textBlink 0.8s infinite;
        }

        /* 3. CHESS LAYOUT STYLING */
        .chess-layout {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 24px;
            width: 100%;
            height: 100%;
            align-items: center;
        }

        .chess-panel {
            display: flex;
            flex-direction: column;
            gap: 16px;
            background: rgba(0,0,0,0.4);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 16px;
            padding: 20px;
            height: 100%;
            justify-content: space-between;
        }

        .chess-panel h3 {
            font-family: 'Anton', sans-serif;
            font-size: 1.4rem;
            color: var(--yellow);
            letter-spacing: 1px;
            margin: 0;
        }

        .chess-meta {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .chess-turn-indicator {
            background: rgba(0, 229, 255, 0.08);
            border: 1px solid rgba(0, 229, 255, 0.2);
            padding: 10px;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 900;
            text-align: center;
            color: var(--cyan);
            letter-spacing: 1px;
        }

        .chess-log {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.5);
            background: rgba(0,0,0,0.3);
            border-radius: 8px;
            padding: 10px;
            min-height: 60px;
            max-height: 80px;
            overflow-y: auto;
            border-left: 3px solid var(--yellow);
        }

        .chess-board-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .chess-board {
            display: grid;
            grid-template-columns: repeat(8, 48px);
            grid-template-rows: repeat(8, 48px);
            border: 4px solid var(--pink);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0,0,0,0.8);
        }

        .chess-square {
            width: 48px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            cursor: pointer;
            user-select: none;
            transition: all 0.2s;
            position: relative;
        }

        .chess-square-light {
            background: #251a3a;
        }

        .chess-square-dark {
            background: #0f0b1a;
        }

        .chess-square-selected {
            background: rgba(255, 230, 0, 0.25) !important;
            box-shadow: inset 0 0 12px var(--yellow);
        }

        .chess-square-valid::after {
            content: '';
            position: absolute;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: var(--cyan);
            box-shadow: 0 0 8px var(--cyan);
        }

        /* 4. LUDO LAYOUT STYLING */
        .ludo-layout {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 24px;
            width: 100%;
            height: 100%;
            align-items: center;
        }

        .ludo-panel {
            display: flex;
            flex-direction: column;
            gap: 16px;
            background: rgba(0,0,0,0.4);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 16px;
            padding: 20px;
            height: 100%;
            justify-content: space-between;
        }

        .ludo-panel h3 {
            font-family: 'Anton', sans-serif;
            font-size: 1.4rem;
            color: var(--yellow);
            letter-spacing: 1px;
            margin: 0;
        }

        .ludo-board-controls {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .dice-roll-btn {
            flex: 1;
            background: var(--yellow);
            border: none;
            color: #000;
            font-family: 'Anton', sans-serif;
            font-size: 1rem;
            letter-spacing: 1px;
            padding: 14px;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 4px 12px rgba(255, 209, 102, 0.4);
        }

        .dice-roll-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(255, 209, 102, 0.6);
        }

        .dice-result {
            width: 50px;
            height: 50px;
            background: #fff;
            border: 3px solid #000;
            color: #000;
            font-size: 20px;
            font-weight: 900;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: inset 2px 2px 5px rgba(0,0,0,0.2);
            animation: bounce 0.4s ease;
        }

        .ludo-status-panel {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .ludo-log {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.5);
            background: rgba(0,0,0,0.3);
            border-radius: 8px;
            padding: 10px;
            min-height: 50px;
            max-height: 70px;
            overflow-y: auto;
            border-left: 3px solid var(--pink);
        }

        .ludo-board-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .ludo-visual-board {
            display: grid;
            grid-template-columns: repeat(7, 48px);
            grid-template-rows: repeat(5, 48px);
            gap: 3px;
            background: #0f0b1d;
            border: 4px solid var(--pink);
            border-radius: 16px;
            padding: 12px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.8);
            position: relative;
        }

        .ludo-track-cell {
            width: 48px;
            height: 48px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Anton', sans-serif;
            color: rgba(255,255,255,0.15);
            font-size: 14px;
            position: relative;
        }

        .ludo-cell-inactive {
            visibility: hidden;
            background: transparent;
            border: none;
        }

        .ludo-cell-start-red {
            background: rgba(255, 0, 140, 0.15);
            border: 2px solid var(--pink);
        }

        .ludo-cell-start-green {
            background: rgba(0, 255, 102, 0.15);
            border: 2px solid var(--neon-glow);
        }

        .ludo-cell-home {
            background: rgba(255, 209, 102, 0.2);
            border: 2.5px dashed var(--yellow);
            color: var(--yellow) !important;
            font-size: 20px !important;
        }

        .ludo-token {
            position: absolute;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            border: 2px solid #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            font-size: 11px;
            box-shadow: 0 0 8px rgba(0,0,0,0.6);
            z-index: 10;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .ludo-token-player {
            background: var(--pink);
            box-shadow: 0 0 12px var(--pink);
        }

        .ludo-token-ai {
            background: var(--neon-glow);
            box-shadow: 0 0 12px var(--neon-glow);
        }

        /* ============================================================
           C. DEALS MARKETPLACE STYLING
           ============================================================ */
        .deals-layout {
            display: flex;
            flex-direction: column;
            gap: 24px;
            height: 100%;
            overflow-y: auto;
        }

        .deals-title {
            font-family: 'Anton', sans-serif;
            font-size: 2rem;
            color: #fff;
            letter-spacing: 1px;
        }

        .deals-desc {
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.6);
        }

        .deals-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
            gap: 24px;
        }

        .deal-coupon-card {
            background: linear-gradient(135deg, rgba(23, 14, 40, 0.95) 0%, rgba(12, 6, 22, 0.98) 100%);
            border: 2px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            overflow: hidden;
            position: relative;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
        }

        .deal-coupon-card:hover {
            border-color: var(--pink);
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 15px 35px rgba(255, 0, 140, 0.3), 0 0 15px rgba(0, 229, 255, 0.15);
        }

        /* Diagonal corner ribbon for discount percentage */
        .deal-discount-ribbon {
            position: absolute;
            top: 15px;
            left: -35px;
            background: linear-gradient(90deg, #ff0055, #ff5e00);
            color: #fff;
            font-size: 0.65rem;
            font-weight: 900;
            padding: 4px 35px;
            transform: rotate(-45deg);
            box-shadow: 0 3px 6px rgba(0,0,0,0.3);
            letter-spacing: 1.5px;
            border-bottom: 1.5px solid #fff;
            z-index: 5;
            text-shadow: 1px 1px #000;
        }

        .coupon-price-badge {
            background: #000;
            color: var(--yellow);
            font-size: 0.68rem;
            font-weight: 900;
            padding: 5px 14px;
            position: absolute;
            top: 15px;
            right: 15px;
            border-radius: 999px;
            letter-spacing: 1px;
            border: 2.5px solid var(--yellow);
            box-shadow: 0 0 10px rgba(255, 230, 0, 0.3);
            z-index: 5;
        }

        /* Neon categories tags inside coupons */
        .deal-tag-neon {
            display: inline-block;
            font-size: 0.6rem;
            font-weight: 900;
            letter-spacing: 1px;
            padding: 3px 8px;
            border-radius: 4px;
            margin-bottom: 10px;
            text-transform: uppercase;
        }
        .tag-food {
            background: rgba(255, 209, 102, 0.1);
            color: #ffd166;
            border: 1px solid #ffd166;
        }
        .tag-clothes {
            background: rgba(255, 0, 140, 0.1);
            color: #ff008c;
            border: 1px solid #ff008c;
        }
        .tag-tech {
            background: rgba(0, 229, 255, 0.1);
            color: #00e5ff;
            border: 1px solid #00e5ff;
        }
        .tag-mega {
            background: rgba(147, 249, 185, 0.1);
            color: #93f9b9;
            border: 1px solid #93f9b9;
            animation: pulseGlowGreen 1.5s infinite alternate;
        }
        @keyframes pulseGlowGreen {
            from { box-shadow: 0 0 4px #93f9b9; }
            to { box-shadow: 0 0 12px #93f9b9; }
        }

        .coupon-content {
            padding: 24px;
        }

        .coupon-content h3 {
            font-family: 'Anton', sans-serif;
            font-size: 1.15rem;
            color: #fff;
            margin-bottom: 4px;
            letter-spacing: 0.5px;
        }

        .coupon-vendor {
            font-size: 0.72rem;
            font-weight: 900;
            color: var(--yellow);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 12px;
        }

        .coupon-details {
            font-size: 0.78rem;
            color: rgba(255, 255, 255, 0.7);
            line-height: 1.5;
            margin-bottom: 20px;
            min-height: 48px;
        }

        .redeem-btn {
            width: 100%;
            background: rgba(255, 255, 255, 0.08);
            border: 1.5px solid rgba(255, 255, 255, 0.15);
            border-radius: 30px;
            padding: 10px;
            color: #fff;
            font-weight: 800;
            font-size: 0.78rem;
            cursor: pointer;
            letter-spacing: 1px;
            text-transform: uppercase;
            transition: all 0.3s;
        }

        .redeem-btn:hover {
            background: #fff;
            color: #000;
            border-color: #fff;
            box-shadow: 0 0 12px rgba(255,255,255,0.35);
        }

        .voucher-claim-box {
            background: rgba(255, 0, 140, 0.05);
            border: 1px dashed var(--pink);
            border-radius: 16px;
            padding: 24px;
            margin-top: 16px;
            display: grid;
            grid-template-columns: 1fr 120px;
            gap: 24px;
            align-items: center;
            position: relative;
            overflow: hidden;
            animation: slideUpClaim 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes slideUpClaim {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .claim-glow {
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at bottom left, rgba(255, 0, 140, 0.12) 0%, transparent 70%);
            pointer-events: none;
        }

        .voucher-claim-box h3 {
            grid-column: span 2;
            font-family: 'Anton', sans-serif;
            font-size: 1rem;
            color: var(--pink);
            letter-spacing: 1px;
            border-bottom: 1px solid rgba(255, 0, 140, 0.15);
            padding-bottom: 8px;
        }

        .claim-details {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .claim-row {
            display: flex;
            justify-content: space-between;
            font-size: 0.8rem;
        }

        .claim-row span {
            color: rgba(255,255,255,0.4);
            font-weight: 700;
        }

        .claim-row strong {
            color: #fff;
            font-weight: 900;
        }

        .neon-text-blink {
            color: var(--cyan) !important;
            animation: textBlinkGlow 1s infinite alternate ease-in-out;
        }

        @keyframes textBlinkGlow {
            0% { text-shadow: 0 0 4px var(--cyan); opacity: 0.85; }
            100% { text-shadow: 0 0 12px var(--cyan); opacity: 1; }
        }

        .simulated-qr {
            width: 100px;
            height: 100px;
            border: 2px solid var(--cyan);
            border-radius: 8px;
            padding: 8px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            background: rgba(0, 229, 255, 0.02);
            box-shadow: 0 0 15px rgba(0, 229, 255, 0.2);
        }

        .qr-dot-row {
            display: flex;
            justify-content: space-between;
            height: 14%;
        }

        .qr-dot-row span {
            width: 14%;
            height: 100%;
            background-color: var(--cyan);
            border-radius: 1px;
        }

        .qr-dot-row span.empty {
            background-color: transparent;
        }

        .claim-info {
            grid-column: span 2;
            font-size: 0.65rem;
            color: rgba(255, 255, 255, 0.4);
            text-align: center;
        }

        /* ============================================================
           D. DOCUMENTATION TERMINAL STYLING
           ============================================================ */
        .docs-layout {
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .docs-terminal {
            flex: 1;
            background: #030107;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 15px 35px rgba(0,0,0,0.8);
        }

        .terminal-bar {
            background: rgba(255,255,255,0.03);
            border-bottom: 1px solid rgba(255,255,255,0.08);
            padding: 12px 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .terminal-bar .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            display: inline-block;
        }

        .terminal-bar .dot.red { background-color: var(--red); }
        .terminal-bar .dot.yellow { background-color: var(--yellow); }
        .terminal-bar .dot.green { background-color: var(--ring-1); }

        .terminal-title {
            margin-left: 12px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.68rem;
            color: rgba(255,255,255,0.4);
            font-weight: 700;
        }

        .terminal-content {
            flex: 1;
            padding: 24px;
            overflow-y: auto;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.85);
            line-height: 1.5;
        }

        .terminal-line {
            color: var(--cyan);
            margin-bottom: 12px;
        }

        .terminal-line .prompt {
            color: var(--pink);
            font-weight: 900;
        }

        .terminal-code {
            color: var(--yellow);
            background: rgba(255, 255, 255, 0.01);
            border-left: 2px solid var(--yellow);
            padding-left: 12px;
            margin-bottom: 24px;
            font-family: 'JetBrains Mono', monospace;
            white-space: pre-wrap;
        }

        .terminal-text h3 {
            font-family: 'Anton', sans-serif;
            font-size: 1.2rem;
            color: #fff;
            margin-bottom: 12px;
            letter-spacing: 0.5px;
        }

        .terminal-text p {
            margin-bottom: 14px;
            color: rgba(255,255,255,0.7);
        }

        .terminal-text strong {
            color: var(--pink);
        }

        /* Immersive Modals Responsive adjustments */
        @media (max-width: 900px) {
            .webtoons-layout {
                grid-template-columns: 1fr;
                gap: 20px;
            }
            .webtoons-sidebar {
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.08);
                padding-right: 0;
                padding-bottom: 16px;
            }
            .games-layout {
                grid-template-columns: 1fr;
                gap: 20px;
            }
            .game-viewport {
                width: 100%;
                max-width: 360px;
                height: 360px;
                margin: 0 auto;
            }
        }

        @media (max-width: 1200px) {
            .interactive-sidebar { display: none; }
            .bottom-console { grid-template-columns: 1fr; gap: 12px; padding: 18px; }
            .ui-desc, .compact-deal-box { display: none; }
            .ring-nav-btn { width: 56px; height: 56px; }
            .ring-nav-left { left: 12px; } .ring-nav-right { right: 12px; }
            .aaa-diorama-card { display: none; }
            .action-sequence { display: none; }
            .location-sign { display: none; }
            .palm { display: none; }
        }
    </style>
</head>
<body>

    <!-- React Mount Root (Remains entirely quiet to avoid overriding DOM layout) -->
    <div id="root"></div>

    <!-- ============================================================
         1. CINEMATIC INTRO HUD
         ============================================================ -->
    <div id="intro">
        <div id="camera" class="camera-breath">
            <!-- Sky vectors -->
            <div class="sky-gradient"></div>
            <div class="stars-bg"></div>
            <div class="sun-disc">
                <!-- Custom dripping golden sun SVG from attached image -->
                <svg viewBox="0 0 400 400" width="100%" height="100%" style="overflow: visible;">
                    <defs>
                        <radialGradient id="goldMeltingGradient" cx="50%" cy="40%" r="50%">
                            <stop offset="0%" stop-color="#fffcef" />
                            <stop offset="35%" stop-color="#ffe600" />
                            <stop offset="70%" stop-color="#ff5e00" />
                            <stop offset="100%" stop-color="#ff0055" />
                        </radialGradient>
                        <filter id="neonSunGlow">
                            <feGaussianBlur stdDeviation="8" result="coloredBlur"/>
                            <feMerge>
                                <feMergeNode in="coloredBlur"/>
                                <feMergeNode in="coloredBlur"/>
                                <feMergeNode in="SourceGraphic"/>
                            </feMerge>
                        </filter>
                    </defs>
                    <path d="M 60 180 A 140 140 0 1 1 340 180 C 340 220, 320 210, 315 225 C 310 245, 305 330, 295 330 C 285 330, 280 230, 275 235 C 265 245, 270 385, 255 385 C 240 385, 245 240, 235 240 C 225 240, 220 295, 210 295 C 200 295, 195 210, 185 210 C 175 210, 170 355, 155 355 C 140 355, 145 220, 135 225 C 125 230, 120 275, 110 275 C 100 275, 95 190, 85 195 C 75 200, 70 235, 60 180 Z" fill="url(#goldMeltingGradient)" filter="url(#neonSunGlow)" />
                </svg>
            </div>
            <div class="cloud-layer cloud-back"></div>
            <div class="cloud-layer cloud-front"></div>

            <!-- Post Production VFX -->
            <div class="film-grain"></div>
            <div class="scanlines"></div>
            <div class="vignette"></div>
            <div class="lens-flare"></div>

            <!-- Skyline Silhouette -->
            <div class="city-depth"></div>
            <svg class="bandra-skyline" viewBox="0 0 1600 420" preserveAspectRatio="none">
                <!-- Skyline silhouette curves -->
                <path d="M0 420 L0 320 L40 305 L50 200 L90 200 L100 320 L150 320 L160 120 L220 120 L230 320 L280 295 L300 100 L360 100 L380 295 L430 320 L440 150 L480 150 L490 320 L550 275 L570 70 L630 70 L650 275 L710 320 L720 160 L760 160 L770 320 L820 305 L840 115 L890 115 L910 305 L970 320 L980 140 L1020 140 L1030 320 L1090 285 L1100 90 L1150 90 L1170 285 L1220 320 L1230 170 L1270 170 L1280 320 L1340 265 L1360 60 L1420 60 L1440 265 L1490 320 L1520 180 L1570 180 L1590 320 L1600 320 L1600 420 Z"/>
            </svg>

            <!-- Blurred Silhouette of Bandra Fort Tower -->
            <svg class="bandra-fort-silhouette" viewBox="0 0 100 120" preserveAspectRatio="none">
                <path d="M10 120 L10 40 L25 40 L25 10 L35 10 L35 40 L50 40 L50 10 L60 10 L60 40 L75 40 L75 10 L85 10 L85 40 L90 40 L90 120 Z"/>
            </svg>

            <!-- Mount Mary Church Silhouette -->
            <svg id="churchSilhouette" class="church-silhouette" viewBox="0 0 120 160" preserveAspectRatio="none">
                <path d="M10 160 L10 70 L30 70 L30 30 L50 30 L50 10 L70 10 L70 30 L90 30 L90 70 L110 70 L110 160 Z" fill="#030106"/>
                <!-- Spire cross -->
                <line x1="60" y1="5" x2="60" y2="22" stroke="var(--yellow)" stroke-width="2.5"/>
                <line x1="53" y1="11" x2="67" y2="11" stroke="var(--yellow)" stroke-width="2.5"/>
            </svg>

            <!-- Dynamic Sea & Wave Glow -->
            <div class="sea-layer">
                <div class="sea-reflection"></div>
                <div class="sea-wave wave1"></div>
                <div class="sea-wave wave2"></div>
                <div class="sea-wave wave3"></div>
            </div>

            <!-- Traditional Koli Fisherman Boat on the sea -->
            <svg id="fishermanBoat" class="fisherman-boat" viewBox="0 0 100 60">
                <path d="M10 40 L90 40 L80 55 L20 55 Z" fill="#05030a" stroke="var(--cyan)" stroke-width="1.8"/>
                <path d="M50 40 L50 10 L72 25 Z" fill="none" stroke="#fff" stroke-width="2"/>
                <!-- Fisherman sitting -->
                <circle cx="43" cy="38" r="4" fill="#05030a"/>
                <path d="M41 42 L46 42 L44 50 Z" fill="#05030a"/>
            </svg>

            <!-- Bandra-Worli Sea Link Wireframe SVG -->
            <svg id="seaLink" class="sea-link" viewBox="0 0 1600 420" preserveAspectRatio="none">
                <!-- Pillars -->
                <path d="M380 280 L440 40 L500 280 Z" fill="#04020a" stroke="var(--cyan)" stroke-width="2"/>
                <path d="M1100 280 L1160 40 L1220 280 Z" fill="#04020a" stroke="var(--cyan)" stroke-width="2"/>
                <!-- Suspended Deck -->
                <path d="M0 270 Q800 235 1600 270" fill="none" stroke="#fff" stroke-width="3" stroke-dasharray="6 4"/>
                <!-- Cables left tower -->
                <path d="M440 40 L180 270 M440 40 L230 270 M440 40 L280 270 M440 40 L330 270 M440 40 L380 270 M440 40 L500 270 M440 40 L550 270 M440 40 L600 270 M440 40 L650 270" stroke="rgba(0, 229, 255, 0.4)" stroke-width="1.2"/>
                <!-- Cables right tower -->
                <path d="M1160 40 L900 270 M1160 40 L950 270 M1160 40 L1000 270 M1160 40 L1050 270 M1160 40 L1100 270 M1160 40 L1220 270 M1160 40 L1270 270 M1160 40 L1320 270 M1160 40 L1370 270" stroke="rgba(0, 229, 255, 0.4)" stroke-width="1.2"/>
                <!-- Red warning lamps -->
                <circle cx="440" cy="40" r="4.5" fill="var(--red)"/>
                <circle cx="1160" cy="40" r="4.5" fill="var(--red)"/>
            </svg>

            <!-- Palms -->
            <div class="palms">
                <div class="palm palm-left"></div>
                <div class="palm palm-right"></div>
            </div>

            <!-- Street Lights -->
            <div class="street-lights"></div>

            <!-- Cyber Traffic lanes -->
            <div class="traffic-lane" id="taxiLane"></div>
            <div class="traffic-lane" id="rickshawLane" style="bottom: 5vh;"></div>

            <!-- Streaking local train (Left-to-Right) -->
            <div id="train" class="train-wrapper">
                <div class="train">
                    <div class="train-text">MUMBAI LOCAL</div>
                    <div class="train-windows"></div>
                </div>
            </div>

            <!-- Second local train (Right-to-Left) -->
            <div id="train2" class="train-wrapper train-wrapper-2">
                <div class="train train-reverse">
                    <div class="train-text">CENTRAL LINE</div>
                    <div class="train-windows"></div>
                </div>
            </div>

            <!-- Flying flock of birds -->
            <div class="birds" id="birdsContainer">
                <span style="top: 14%; animation-delay: 2s;"></span>
                <span style="top: 20%; animation-delay: 2.3s;"></span>
                <span style="top: 17%; animation-delay: 2.7s;"></span>
            </div>

            <!-- Comic book BOOM sticker panels -->
            <div id="comicPow" class="comic" style="top: 32%; right: 22%;">POW!</div>
            <div id="comicBoom" class="comic" style="top: 18%; left: 10%;">BOOM!</div>
            <div id="comicBam" class="comic" style="bottom: 24%; right: 8%;">BAM!</div>
            <div id="comicLetsGo" class="comic" style="top: 25%; left: 45%;">LET'S GO!</div>
            <div id="comicWow" class="comic" style="bottom: 15%; left: 15%;">WOW!</div>

            <!-- Area nameplates and iconic places of Bandra -->
            <div id="stationBoard" class="station-board">BANDRA STATION</div>
            <div class="location-sign" id="sign1" style="left: 12%; bottom: 22vh;">CARTER ROAD</div>
            <div class="location-sign" id="sign2" style="left: 28%; bottom: 24vh;">PALI HILL</div>
            <div class="location-sign" id="sign3" style="right: 30%; bottom: 23vh;">HILL ROAD</div>
            <div class="location-sign" id="sign4" style="right: 15%; bottom: 21vh;">LINKING ROAD</div>
            <div class="location-sign" id="sign5" style="left: 45%; bottom: 23vh;">BANDSTAND</div>
            <div class="location-sign" id="sign6" style="right: 48%; bottom: 25vh;">CHAPEL ROAD</div>

            <!-- Floating Street culture stickers -->
            <div class="sticker-world" id="stickerWorld">
                <div class="sticker" style="top: 10%; left: 16%;">🎮</div>
                <div class="sticker" style="top: 20%; right: 15%;">🎨</div>
                <div class="sticker" style="bottom: 35%; left: 20%;">🛹</div>
                <div class="sticker" style="bottom: 25%; right: 20%;">⚡</div>
                <div class="sticker" style="top: 6%; left: 50%;">🔥</div>
                <div class="sticker" style="bottom: 15%; left: 42%;">👟</div>
                <div class="sticker" style="top: 28%; left: 6%;">💿</div>
            </div>

            <!-- Massive Chromed Title Reveal -->
            <section id="hero" class="hero">
                <div class="small-title">WELCOME TO THE STREETS OF</div>
                <h1 id="logo">
                    BANDRA
                    <span>HUSTLERS</span>
                </h1>
                <div class="hero-subtitle">MUMBAI • GAMES • WEBTOONS • DEALS • CULTURE</div>
            </section>

            <!-- Active context words pills -->
            <section class="action-sequence" id="actionSequence">
                <span>PLAY</span>
                <span>READ</span>
                <span>BUILD</span>
                <span>CREATE</span>
                <span>EXPLORE</span>
                <span>DISCOVER</span>
            </section>


            <!-- Particle Canvas explosion overlays -->
            <canvas id="particleCanvas"></canvas>

            <!-- Screen flash layer -->
            <div class="white-flash" id="whiteFlash"></div>

            <!-- Marathi Logo Pop art Sticker -->
            <div id="marathiLogo" class="marathi-logo">आमची वांद्रे</div>

            <!-- Bollywood Star Sticker -->
            <div id="bollywoodSticker" class="bollywood-sticker">
                <div class="shades-icon">🕶️⭐</div>
                <div class="star-label">BOLLYWOOD STAR</div>
            </div>
        </div>

        <!-- Audio dynamic helper prompter -->
        <div id="audioPrompt" class="audio-prompt">🔊 TAP ANYWHERE FOR SOUND</div>

        <!-- Glassmorphic Enter Site button -->
        <button class="intro-skip" id="skipButton">
            <span>ENTER SITE</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width: 14px; height: 14px; display: inline-block; margin-left: 6px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
    </div>

    <!-- POP ART STYLE TRANSITION CURTAIN -->
    <div id="popArtTransition" class="pop-art-transition">
        <div class="stripe stripe-pink"></div>
        <div class="stripe stripe-yellow"></div>
        <div class="stripe stripe-cyan"></div>
        <div class="pop-art-text" id="popArtText">आमची वांद्रे</div>
    </div>


    <!-- ============================================================
         2. MAIN INTERACTIVE REVEALED HOMEPAGE
         ============================================================ -->
    <div class="app-container" id="app-root">
        <div class="ambient-shading"></div>
        <div class="grain-overlay"></div>
        
        <!-- Navbar controls -->
        <div class="system-footer">
            <button class="replay-btn" id="replayIntroBtn">⚡ REPLAY CINEMATIC INTRO</button>
        </div>

        <button class="audio-toggle" onclick="toggleMusic()"><span id="m-status">⚡ INITIALIZE SYSTEM AUDIO</span></button>
        
        <div class="ghost-text" id="ghost-title">LUDO</div>
        
        <!-- Rotating concentric circle neon rings -->
        <div class="ring-system">
            <div class="neon-ring-outer"></div>
            <div class="neon-ring-inner"></div>
        </div>

        <!-- Slideshow diorama navigational buttons -->
        <button class="ring-nav-btn ring-nav-left" onclick="navigate('prev')" aria-label="Previous Frame">
            <svg viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="ring-nav-btn ring-nav-right" onclick="navigate('next')" aria-label="Next Frame">
            <svg viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>

        <!-- Slideshow stage & interactive dioramas -->
        <div class="stage-container" id="stage"></div>
        <div class="props-container" id="sticker-layer"></div>


        <!-- Sleek bottom control HUD -->
        <div class="bottom-console">
            <div>
                <div class="brand-meta" id="meta-type">TOY WORLD CHAOS</div>
                <p class="ui-title" id="char-name">LUDO RUNNERS</p>
            </div>

            <div>
                <p class="ui-desc" id="char-desc">Loading visual world engine ecosystems...</p>
            </div>

            <div class="console-right-panel">
                <div class="compact-deal-box">
                    <div>
                        <div style="font-size: 0.55rem; opacity: 0.5; font-weight: 900; text-transform: uppercase;">REALTIME MARKET DROP</div>
                        <div class="deal-vendor" id="deal-vendor">LOADING NODE</div>
                    </div>
                    <div class="deal-text" id="deal-text">UPDATING VIP BADGE METADATA...</div>
                </div>
                <a href="#" class="launcher-btn" onclick="launchGame(event)">ENTER</a>
            </div>
        </div>
    </div>

    <!-- ============================================================
         AAA IMMERSIVE CONSOLE MODALS
         ============================================================ -->
    <div id="systemModal" class="system-modal" style="display: none;">
        <div class="modal-glow-bg"></div>
        <div class="modal-container">
            <!-- Modal Header -->
            <div class="modal-header">
