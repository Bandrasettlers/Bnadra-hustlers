            <!-- Modal Content Panels -->
            <div class="modal-body">
                <!-- 1. Webtoons Panel -->
                <div id="panel-webtoons" class="modal-panel" style="display: none; padding: 24px;">
                    <!-- WEBTOONS SHELF LANDING VIEW -->
